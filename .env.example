JWT_SECRET=canvia_aquest_secret_per_un_aleatori_llarg

# GNews API (registra't gratis a gnews.io)
GNEWS_API_KEY=your-gnews-token-here

# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here
